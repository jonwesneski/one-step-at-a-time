{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "composite": false,
    "declarationMap": false,
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./*"],
      "@one-step-at-a-time/web-components": [
        "../../packages/web-components/src/index.ts"
      ],
      "@one-step-at-a-time/web-components/*": [
        "../../packages/web-components/src/*"
      ]
    }
  },
  "references": [{ "path": "../../packages/web-components" }],
  "include": [
    "app/**/*",
    "vite.config.ts",
    "../../packages/web-components/src/**/*.ts",
    "../../packages/web-components/src/**/*.tsx"
  ],
  "exclude": [
    "../../packages/web-components/src/**/*.test.ts",
    "../../packages/web-components/src/**/*.spec.ts",
    "../../packages/web-components/src/**/*.stories.ts"
  ]
}
