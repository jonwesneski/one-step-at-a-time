{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "declaration": true,
    "declarationMap": true,
    "allowJs": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2022",
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.js", "jest.setup.ts"],
  "references": [],
  "exclude": [
    "jest.config.cjs",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.js",
    "src/**/*.test.js",
    "**/*.stories.ts",
    "**/*.stories.js"
  ]
}
